# Copy to .env and adjust values before running docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=wholesale_user
POSTGRES_PASSWORD=wholesale_password
POSTGRES_DB=wholesale_db
POSTGRES_PORT=5432

# ── Backend ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
RUST_LOG=info
BACKEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_PORT=80
VITE_API_URL=/api
